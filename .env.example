# ============================================================
# rAthena Server Infrastructure - Environment Variables
# ============================================================
# Copie este arquivo para .env e ajuste os valores conforme seu ambiente.
# NUNCA commite o arquivo .env no repositório!
#
# Valores padrão neste arquivo são EXEMPLOS seguros para desenvolvimento.
# Para produção, gere senhas fortes (mínimo 32 caracteres alfanuméricos + especiais).
# O script setup.sh pode gerar senhas automaticamente no primeiro deploy.
# ============================================================

# ------------------------------------------------------------
# GERAL / SERVER
# ------------------------------------------------------------

# Nome do servidor (exibido no cliente e nos dashboards)
SERVER_NAME=MyRO

# Versão do protocolo do cliente RO (formato YYYYMMDD)
# Deve corresponder à versão do seu cliente de jogo
PACKETVER=20211103

# Branch ou tag do repositório rAthena para compilação
RATHENA_BRANCH=master

# ------------------------------------------------------------
# MARIADB (Banco de Dados Principal)
# ------------------------------------------------------------

# Senha do usuário root do MariaDB
# PRODUÇÃO: Use senha forte de 32+ caracteres gerada pelo setup.sh
MARIADB_ROOT_PASSWORD=change_me_root_password_32chars!

# Host do banco de dados (nome do container no Docker Compose)
DB_HOST=mariadb

# Porta do MariaDB (interna, não exposta ao host)
DB_PORT=3306

# Nome do banco de dados principal do rAthena
RATHENA_DB_NAME=ragnarok

# Nome do banco de dados de logs do rAthena
RATHENA_LOG_DB_NAME=ragnarok_log

# Número máximo de conexões simultâneas ao MariaDB
# Ajustar conforme número esperado de jogadores (padrão: 151)
DB_MAX_CONNECTIONS=151

# ------------------------------------------------------------
# RATHENA (Servidores de Jogo)
# ------------------------------------------------------------

# Usuário do banco de dados para os servidores rAthena
RATHENA_DB_USER=rathena

# Senha do usuário rAthena no banco de dados
# PRODUÇÃO: Use senha forte de 32+ caracteres
RATHENA_DB_PASSWORD=change_me_rathena_db_password!!

# Senha de comunicação entre Login/Char/Map servers
# PRODUÇÃO: Use senha forte e única de 32+ caracteres
INTER_SERVER_PASSWORD=change_me_inter_server_password

# Endereço IP público do servidor (para conexão dos jogadores)
# Em produção, defina o IP público real do servidor
SERVER_PUBLIC_IP=127.0.0.1

# Portas dos serviços rAthena
LOGIN_SERVER_PORT=6900
CHAR_SERVER_PORT=6121
MAP_SERVER_PORT=5121

# Limite de tentativas de registro/login por IP na janela de tempo
# Previne brute-force de contas (0 = ilimitado, não recomendado)
LOGIN_ALLOWED_REGS=5

# Janela de tempo em segundos para o limite de tentativas
LOGIN_TIME_ALLOWED=60

# Endereço de bind do login-server (0.0.0.0 aceita de todas as interfaces)
LOGIN_BIND_IP=0.0.0.0

# Permitir criação de novas contas in-game (yes/no)
LOGIN_NEW_ACCOUNT=yes

# Habilitar ban de IP por tentativas falhas (yes/no)
LOGIN_IPBAN_ENABLE=yes

# Usar hash MD5 para senhas (yes/no)
LOGIN_USE_MD5=no

# Verificação de hash do cliente (anti-cheat) (0=off, 1=on)
LOGIN_HASH_CHECK=0

# IP do login-server para comunicação inter-server
LOGIN_SERVER_IP=127.0.0.1

# IP de bind do char-server
CHAR_BIND_IP=0.0.0.0

# Ponto de início dos personagens (mapa,x,y)
CHAR_START_POINT=new_1-1,53,111

# Zeny inicial de novos personagens
CHAR_START_ZENY=0

# Máximo de personagens por conta
CHAR_PER_ACCOUNT=9

# Delay para deletar personagem (em segundos, 86400 = 1 dia)
CHAR_DEL_DELAY=86400

# Restrição de caracteres no nome (0=qualquer, 1=só letras)
CHAR_NAME_LETTERS=0

# Opção de nome (0=sem restrição, 1=sem espaços, 2=sem espaços e símbolos)
CHAR_NAME_OPTION=1

# Habilitar sistema de pincode (yes/no)
CHAR_PINCODE_ENABLED=yes

# IP do char-server para comunicação inter-server
CHAR_SERVER_IP=127.0.0.1

# IP de bind do map-server
MAP_BIND_IP=0.0.0.0

# Intervalo de autosave do mapa (em segundos)
MAP_AUTOSAVE_TIME=300

# Intervalo mínimo de save (em segundos)
MAP_MINSAVE_TIME=100

# Usar SQL para banco de mobs/itens (yes/no)
MAP_USE_SQL_DB=no

# Codepage do banco de dados
DB_CODEPAGE=utf8

# Formato de timestamp nos logs
LOG_TIMESTAMP_FORMAT=[%Y-%m-%d %H:%M:%S]

# ------------------------------------------------------------
# ZABBIX (Monitoramento)
# ------------------------------------------------------------

# Usuário do banco de dados para o Zabbix
ZBX_DB_USER=zabbix

# Senha do usuário Zabbix no banco de dados
# PRODUÇÃO: Use senha forte de 32+ caracteres
ZBX_DB_PASSWORD=change_me_zabbix_db_password!!!

# Nome do banco de dados do Zabbix (separado do rAthena)
ZBX_DB_NAME=zabbix

# Host do servidor Zabbix (nome do container)
ZBX_SERVER_HOST=zabbix-server

# Timezone para interface web do Zabbix
ZBX_SERVER_TIMEZONE=America/Sao_Paulo

# ------------------------------------------------------------
# GRAFANA (Dashboards e Visualização)
# ------------------------------------------------------------

# Usuário administrador do Grafana
GF_SECURITY_ADMIN_USER=admin

# Senha do administrador do Grafana
# PRODUÇÃO: Use senha forte de 32+ caracteres
GF_SECURITY_ADMIN_PASSWORD=change_me_grafana_admin_pass!!!

# Porta de acesso ao Grafana
GF_SERVER_HTTP_PORT=3000

# Plugins a instalar automaticamente (Zabbix datasource)
GF_INSTALL_PLUGINS=alexanderzobnin-zabbix-app

# ------------------------------------------------------------
# FLUXCP (Painel de Controle Web)
# ------------------------------------------------------------

# Usuário do banco de dados para o FluxCP
FLUXCP_DB_USER=fluxcp

# Senha do usuário FluxCP no banco de dados
# PRODUÇÃO: Use senha forte de 32+ caracteres
FLUXCP_DB_PASSWORD=change_me_fluxcp_db_password!!!

# Porta de acesso ao FluxCP
FLUXCP_PORT=80

# URL base do FluxCP (para links e redirecionamentos)
FLUXCP_BASE_URL=http://localhost

# ------------------------------------------------------------
# BACKUP (Backup Automatizado)
# ------------------------------------------------------------

# Usuário do banco de dados dedicado a backup (somente leitura)
BACKUP_DB_USER=rathena_backup

# Senha do usuário de backup
# PRODUÇÃO: Use senha forte de 32+ caracteres
BACKUP_DB_PASSWORD=change_me_backup_db_password!!!!

# Horário do backup diário (formato cron: minuto hora)
# Padrão: 04:00 UTC
BACKUP_CRON_SCHEDULE=0 4 * * *

# Dias de retenção dos backups (backups mais antigos são removidos)
BACKUP_RETENTION_DAYS=30

# URL do webhook para notificação de falha de backup
# Suporta Discord, Telegram e Slack
# Discord: https://discord.com/api/webhooks/ID/TOKEN
# Slack: https://hooks.slack.com/services/T00/B00/XXXX
# Telegram: https://api.telegram.org/botTOKEN/sendMessage?chat_id=CHATID
BACKUP_WEBHOOK_URL=

# ------------------------------------------------------------
# AUTOHEAL (Recuperação Automática)
# ------------------------------------------------------------

# Monitorar todos os containers ou apenas os com label específica
# all = monitora todos os containers com healthcheck
AUTOHEAL_CONTAINER_LABEL=all

# Intervalo de verificação do Autoheal (segundos)
AUTOHEAL_INTERVAL=5

# ------------------------------------------------------------
# DEPLOY / CI-CD
# ------------------------------------------------------------

# Registry de imagens Docker (GitHub Container Registry)
DOCKER_REGISTRY=ghcr.io

# Organização/usuário no registry
DOCKER_ORG=m1crocorp

# Tag das imagens (gerada automaticamente pelo CI/CD)
# Em desenvolvimento, use 'latest' ou uma tag fixa
IMAGE_TAG=latest

# ------------------------------------------------------------
# HOST / REDE
# ------------------------------------------------------------

# Porta SSH do servidor (alterar da padrão 22 para segurança)
SSH_PORT=22

# Timezone do servidor host
TZ=America/Sao_Paulo
